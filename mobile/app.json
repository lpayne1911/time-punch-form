{
  "expo": {
    "name": "Velvet",
    "slug": "velvet",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "velvet",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#100b16",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.velvet.app",
      "buildNumber": "1"
    },
    "android": {
      "package": "com.velvet.app",
      "edgeToEdgeEnabled": true
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "themeColor": "#100b16"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
